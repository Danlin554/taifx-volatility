# Zeabur Postgres（與 FB-Market 共用，tvol_ 前綴完全隔離）
DATABASE_URL=postgresql://postgres:yourpassword@host:5432/zeabur

# 每日 cron refresh 的驗證 token（隨機生成一組）
REFRESH_TOKEN=replace-with-random-secret

# 富邦 API 憑證（選填；未設定時自動切換 FinMind 備援）
FUBON_ID=
FUBON_PWD=
FUBON_CERT_PATH=/path/to/cert.pfx
FUBON_CERT_PWD=

# FinMind API token（選填；空白使用免費層 600 req/hr）
FINMIND_TOKEN=
