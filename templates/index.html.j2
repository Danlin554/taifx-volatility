<!-- ── 使用指南 ── -->
<div class="card">
  <div class="card-title"><span class="ct-icon">📖</span>使用指南</div>
  <div class="guide">
    <p>· 震幅數據每日 <strong>06:00</strong> 自動更新，右上角可切換查詢歷史日期（資料從 {{ earliest_db_date or '—' }} 起）。</p>
    <p>· <strong>單位風險 R</strong>：一口停損點數。預估獲利 ÷ R = 盈虧比，可依個人風控調整。</p>
    <p>· <strong>合理範圍</strong>：期貨預估 × (1 ± 0.5%)，開盤後的合理波動區間。</p>
    <p>· <strong>σ 震幅</strong>：10 日振幅均值 ± N 個標準差，用以評估行情空間與停利時機。</p>
    <p>· <strong>美股漲跌幅</strong>：加權平均後預估台指開盤，評估方向偏多/偏空。</p>
    <p>· <strong>一壘打</strong>：近 20 日最小振幅 — 低能量日合理目標。</p>
    <p>· <strong>二壘打</strong>：弱勢日（低於均值）的平均振幅。</p>
    <p>· <strong>三壘打</strong>：20 日平均振幅 — 一般日標準預期。</p>
    <p>· <strong>全壘打</strong>：強勢日（高於均值）的平均振幅。</p>
    <p>· <strong>場外全壘打</strong>：近 20 日最大振幅 — 極端行情天花板。</p>
    <p>· <strong>多方 / 空方目標</strong>：D+1 預估開盤 ± 各壘打振幅，分別給出做多 / 做空獲利目標位。</p>
    <p>· <strong>權重與 R</strong>：調整後自動儲存至瀏覽器本機，重新整理後仍保留。</p>
  </div>
</div>

<div class="footer">
  自動更新 · <span id="gen-at">{{ generated_at }}</span> · 台指 FinMind (TX) · 美股 yfinance
</div>
</div>

<script>
// ────────────────────────────────────────────────────────
// 伺服器初始資料（Jinja2 注入）
// ────────────────────────────────────────────────────────
window._TARGETS = {{ targets | tojson }};
window._CURRENT_ASOF = '{{ effective_date or asof_iso }}';
window._calendarAnomaly = '{{ calendar_anomaly or "none" }}';

// ────────────────────────────────────────────────────────
// 輔助函式
// ────────────────────────────────────────────────────────
function roundHalfUp(x) { return Math.floor(x + 0.5); }

function n(id) { return parseFloat(document.getElementById(id)?.value) || 0; }

function setText(id, v) {
  const el = document.getElementById(id);
  if (el) el.textContent = (v === null || v === undefined || v === '') ? '—' : v;
}
function setVal(id, v) {
  const el = document.getElementById(id);
  if (el && v !== null && v !== undefined) el.value = v;
}

function fmt(v, dec) {
  if (v === null || v === undefined || isNaN(Number(v))) return '—';
  return Number(v).toFixed(dec !== undefined ? dec : 2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

function showToast(msg) {
  const el = document.getElementById('_toast');
  if (!el) return;
  el.textContent = msg;
  el.style.opacity = '1';
  clearTimeout(el._t);
  el._t = setTimeout(() => { el.style.opacity = '0'; }, 3500);
}

function fmtDatetime(iso) {
  if (!iso) return '';
  try {
    return new Date(iso).toLocaleString('zh-TW', { timeZone: 'Asia/Taipei',
      year: 'numeric', month: '2-digit', day: '2-digit',
      hour: '2-digit', minute: '2-digit' });
  } catch { return iso; }
}

// ────────────────────────────────────────────────────────
// localStorage（只存使用者自訂欄位）
// ────────────────────────────────────────────────────────
const SAVE_KEYS = ['djW','nqW','spyW','tsmW','rR'];

function loadPersistentState() {
  SAVE_KEYS.forEach(k => {
    const v = localStorage.getItem('taifx_' + k);
    if (v !== null) { const el = document.getElementById(k); if (el) el.value = v; }
  });
}

function save() {
  SAVE_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) localStorage.setItem('taifx_' + k, el.value);
  });
}

// ────────────────────────────────────────────────────────
// 計算
// ────────────────────────────────────────────────────────
function calculate() {
  save();

  // Case 1：美股假日無開盤 → 所有預估卡片顯示「—」，不做計算
  if (window._calendarAnomaly === 'us_no_session') {
    const wEl = document.getElementById('wChg');
    if (wEl) { wEl.textContent = '—'; wEl.style.color = ''; }
    ['futEst','rLow','rHigh','open-price-display'].forEach(id => setText(id, '—'));
    ['b1','b2','b3','b4','b5'].forEach(k => {
      setText('long-'  + k, '—');
      setText('short-' + k, '—');
    });
    return;
  }

  const djC=n('djC'), djW=n('djW');
  const nqC=n('nqC'), nqW=n('nqW');
  const spyC=n('spyC'), spyW=n('spyW');
  const tsmC=n('tsmC'), tsmW=n('tsmW');
  const prev=n('prevClose');
  const a10=n('a10'), s10=n('s10');

  const totalW = djW + nqW + spyW + tsmW;
  const wChg = totalW > 0
    ? (djC*djW + nqC*nqW + spyC*spyW + tsmC*tsmW) / totalW
    : 0;

  const futEst = roundHalfUp(prev * (1 + wChg / 100));
  const rLow  = roundHalfUp(futEst * 0.995);
  const rHigh = roundHalfUp(futEst * 1.005);

  const sig1 = a10 + s10;
  const sig2 = a10 + 2 * s10;
  const sig3 = a10 + 3 * s10;

  const wEl = document.getElementById('wChg');
  if (wEl) {
    wEl.textContent = (wChg >= 0 ? '+' : '') + wChg.toFixed(2) + '%';
    wEl.style.color = wChg >= 0 ? '#16a34a' : '#dc2626';
  }

  setText('futEst', futEst.toLocaleString());
  setText('rLow', rLow.toLocaleString());
  setText('rHigh', rHigh.toLocaleString());
  setText('sig1', fmt(sig1, 1));
  setText('sig2', fmt(sig2, 1));
  setText('sig3', fmt(sig3, 1));

  // 多空目標
  const targets = window._TARGETS || {};
  setText('open-price-display', futEst.toLocaleString());
  ['b1','b2','b3','b4','b5'].forEach(k => {
    const t = targets[k] || 0;
    setText('long-'  + k, roundHalfUp(futEst + t).toLocaleString());
    setText('short-' + k, roundHalfUp(futEst - t).toLocaleString());
  });
}

// ────────────────────────────────────────────────────────
// patchDOM：切換日期後更新快照欄位（不動 weights/R）
// ────────────────────────────────────────────────────────
function patchDOM(data) {
  // 美股漲幅：優先用 us_data.<k>.pct（toFixed(2)），fallback us.<k>
  const fmtPct = (v) => (v === null || v === undefined || isNaN(Number(v))) ? '' : (+v).toFixed(2);
  if (data.us_data) {
    setVal('djC',  fmtPct(data.us_data.dj?.pct));
    setVal('nqC',  fmtPct(data.us_data.nq?.pct));
    setVal('spyC', fmtPct(data.us_data.spy?.pct));
    setVal('tsmC', fmtPct(data.us_data.tsm?.pct));
    setText('djClose',  data.us_data.dj?.close?.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}));
    setText('nqClose',  data.us_data.nq?.close?.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}));
    setText('spyClose', data.us_data.spy?.close?.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}));
    setText('tsmClose', data.us_data.tsm?.close?.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}));
  } else if (data.us) {
    setVal('djC',  fmtPct(data.us.dj));
    setVal('nqC',  fmtPct(data.us.nq));
    setVal('spyC', fmtPct(data.us.spy));
    setVal('tsmC', fmtPct(data.us.tsm));
  }

  // 台指期 OHLC（B5.3 A/C）
  if (data.txf_ohlc) {
    setText('txfOpen',  Math.round(data.txf_ohlc.open).toLocaleString());
    setText('txfHigh',  Math.round(data.txf_ohlc.high).toLocaleString());
    setText('txfLow',   Math.round(data.txf_ohlc.low).toLocaleString());
    setText('txfClose', Math.round(data.txf_ohlc.close).toLocaleString());
    // hidden input 同步，維持 calculate() 既有契約
    setVal('prevClose', data.txf_ohlc.close);
    const label = data.txf_symbol_label || '大臺近月（TXFR1）日盤';
    setText('txf-meta', label + ' · ' + (data.txf_ohlc.date || '—'));
  } else if (data.prev_close !== undefined) {
    setVal('prevClose', data.prev_close);
  }

  // NYSE 收盤 meta badge（用 us_session_close_tpe，DST/半日交易日由後端 calendar 推導）
  const fmtTpe = (iso) => {
    if (!iso) return '收盤後';
    try {
      const d = new Date(iso);
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      const hh = String(d.getHours()).padStart(2, '0');
      const mm = String(d.getMinutes()).padStart(2, '0');
      return `${m}-${day} ${hh}:${mm}`;
    } catch { return '收盤後'; }
  };
  if (data.us_session_date) {
    setText('us-meta', `NYSE 收盤 ${data.us_session_date}（台北 ${fmtTpe(data.us_session_close_tpe)}）`);
  }

  if (data.stats) {
    setVal('a20', data.stats.a20); setVal('a10', data.stats.a10); setVal('a5',  data.stats.a5);
    setVal('s20', data.stats.s20); setVal('s10', data.stats.s10); setVal('s5',  data.stats.s5);
  }

  if (data.atr) {
    setText('atr20', data.atr.atr20);
    setText('atr10', data.atr.atr10);
    setText('atr5',  data.atr.atr5);
  }

  window._TARGETS = data.targets || {};
  if (data.targets) {
    ['b1','b2','b3','b4','b5'].forEach(k => setText('tgt-' + k, data.targets[k]));
  }

  if (data.weekday) {
    ['mon','tue','wed','thu','fri'].forEach(wd => setText('wd-' + wd, data.weekday[wd]));
  }

  const staleBanner = document.getElementById('stale-banner');
  if (staleBanner) {
    staleBanner.hidden = !data.is_stale;
    if (data.is_stale) {
      const td = data.trading_date || data.effective_date || '';
      staleBanner.textContent = td
        ? `⚠ 資料尚未更新（適用交易日 ${td}），請等待下次自動更新。`
        : '⚠ 資料尚未更新，請等待下次自動更新。';
    }
  }

  const adjBanner = document.getElementById('adj-banner');
  const adjText = document.getElementById('adj-banner-text');
  if (adjBanner) {
    const anomaly = data.calendar_anomaly;
    const win = data.us_aggregation_window;
    if (anomaly === 'us_no_session') {
      adjBanner.hidden = false;
      if (adjText) adjText.textContent = `美股 ${data.us_session_date || data.effective_date || '—'} 無開盤，今日預估開盤暫不適用`;
    } else if (anomaly === 'tw_holiday_gap' && win) {
      adjBanner.hidden = false;
      if (adjText) adjText.textContent = `台股連休期間美股共有 ${win.session_count} 個交易日，漲跌幅以 ${win.start} ～ ${win.end} 區間累積計算`;
    } else if (data.asof_adjusted_from) {
      adjBanner.hidden = false;
      if (adjText) adjText.textContent = `${data.asof_adjusted_from} 非交易日，顯示最近交易日資料（${data.resolved_effective_date || ''}）`;
    } else {
      adjBanner.hidden = true;
    }
  }

  // 同步 calendar anomaly 狀態（影響 calculate() 的顯示模式）
  window._calendarAnomaly = data.calendar_anomaly || 'none';
  const cumChip = document.getElementById('cum-chip');
  if (cumChip) cumChip.hidden = (data.calendar_anomaly !== 'tw_holiday_gap');

  const dsEl = document.getElementById('data-source-badge');
  if (dsEl) {
    const isLive = data.data_source === 'live';
    dsEl.textContent = isLive ? 'LIVE' : 'DB';
    dsEl.className = 'src-badge ' + (isLive ? 'src-live' : 'src-db');
  }

  const metaEl = document.getElementById('effective-meta');
  if (metaEl) {
    const displayDate = data.trading_date || data.effective_date;
    if (displayDate) metaEl.textContent = `適用交易日 ${displayDate}`;
  }

  setText('gen-at', fmtDatetime(data.generated_at));

  // B5.3 C：所有欄位更新後重算加權預估（hidden prevClose 已換值）
  calculate();
}

// ────────────────────────────────────────────────────────
// switchDate：AbortController + latest-wins token
// ────────────────────────────────────────────────────────
let _currentController = null;
let _latestToken = 0;
let _currentDisplayedAsof = window._CURRENT_ASOF;

async function switchDate(asof) {
  if (_currentController) _currentController.abort();
  const myToken = ++_latestToken;
  _currentController = new AbortController();
  document.body.classList.add('loading');
  try {
    const res = await fetch('/api/snapshot?asof=' + asof, { signal: _currentController.signal });
    if (myToken !== _latestToken) return;
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      const code = body.detail?.code || body.detail || res.status;
      showToast(`無法載入 ${asof}：${code}`);
      const dateEl = document.getElementById('openDate');
      if (dateEl && _currentDisplayedAsof) dateEl.value = _currentDisplayedAsof;
      return;
    }
    const data = await res.json();
    if (myToken !== _latestToken) return;
    patchDOM(data);
    loadPersistentState();
    calculate();
    _currentDisplayedAsof = data.resolved_effective_date || asof;
    if (data.asof_adjusted_from) {
      showToast(`${data.asof_adjusted_from} 資料尚未入庫，顯示 ${data.resolved_effective_date}`);
    }
  } catch (e) {
    if (e.name === 'AbortError') return;
    if (myToken !== _latestToken) return;
    showToast('網路錯誤，請稍後再試');
  } finally {
    if (myToken === _latestToken) {
      document.body.classList.remove('loading');
      _currentController = null;
    }
  }
}

// ────────────────────────────────────────────────────────
// 初始化
// ────────────────────────────────────────────────────────
document.querySelectorAll('input').forEach(el => el.addEventListener('input', calculate));

document.getElementById('openDate').addEventListener('change', function() {
  const val = this.value;
  if (val) switchDate(val);
});

(function() {
  const el = document.getElementById('gen-at');
  if (el) el.textContent = fmtDatetime(el.textContent.trim()) || el.textContent;
})();

loadPersistentState();
calculate();

// Bootstrap: 用 fresh /api/snapshot 蓋掉預渲染 HTML 的凍結值
// （server_today / is_stale 必須以「現在」為準，而非 cron 跑時的快照值）
async function bootstrapFresh() {
  try {
    const res = await fetch('/api/snapshot', { cache: 'no-store' });
    if (!res.ok) return;
    const data = await res.json();
    const freshTradingDate = data.trading_date || data.server_today;
    const dateEl = document.getElementById('openDate');
    if (dateEl && data.server_today) {
      const prevMax = dateEl.max;
      dateEl.max = data.server_today;
      // 若 picker 仍是預渲染時的值（使用者尚未互動）且 fresh trading_date 比較新 → bump
      if (dateEl.value === prevMax && freshTradingDate && freshTradingDate > prevMax) {
        dateEl.value = freshTradingDate;
      }
    }
    const metaEl = document.getElementById('effective-meta');
    if (metaEl && freshTradingDate) {
      metaEl.textContent = `適用交易日 ${freshTradingDate}`;
    }
    const staleBanner = document.getElementById('stale-banner');
    if (staleBanner) {
      staleBanner.hidden = !data.is_stale;
      if (data.is_stale) {
        const td = freshTradingDate || data.effective_date || '';
        staleBanner.textContent = td
          ? `⚠ 資料尚未更新（適用交易日 ${td}），請等待下次自動更新。`
          : '⚠ 資料尚未更新，請等待下次自動更新。';
      }
    }

    const adjBannerFresh = document.getElementById('adj-banner');
    const adjTextFresh = document.getElementById('adj-banner-text');
    if (adjBannerFresh) {
      const anomaly = data.calendar_anomaly;
      const win = data.us_aggregation_window;
      if (anomaly === 'us_no_session') {
        adjBannerFresh.hidden = false;
        if (adjTextFresh) adjTextFresh.textContent = `美股 ${data.us_session_date || data.effective_date || '—'} 無開盤，今日預估開盤暫不適用`;
      } else if (anomaly === 'tw_holiday_gap' && win) {
        adjBannerFresh.hidden = false;
        if (adjTextFresh) adjTextFresh.textContent = `台股連休期間美股共有 ${win.session_count} 個交易日，漲跌幅以 ${win.start} ～ ${win.end} 區間累積計算`;
      } else if (data.asof_adjusted_from) {
        adjBannerFresh.hidden = false;
        if (adjTextFresh) adjTextFresh.textContent = `${data.asof_adjusted_from} 非交易日，顯示最近交易日資料（${data.resolved_effective_date || ''}）`;
      } else {
        adjBannerFresh.hidden = true;
      }
    }
    window._calendarAnomaly = data.calendar_anomaly || 'none';
    const cumChipFresh = document.getElementById('cum-chip');
    if (cumChipFresh) cumChipFresh.hidden = (data.calendar_anomaly !== 'tw_holiday_gap');
  } catch (e) {
    // 靜默：bootstrap 失敗就用凍結值，不影響主要功能
  }
}
bootstrapFresh();
</script>
</body>
</html>
