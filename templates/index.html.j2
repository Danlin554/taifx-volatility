<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>台指平均震幅分析工具</title>
<style>
/* ── Design tokens ── */
:root {
  --bg:       #f0f2f5;
  --surface:  #ffffff;
  --surface2: #f8f9fa;
  --border:   #e0e0e0;
  --border2:  #f0f0f0;
  --text:     #1a1a2e;
  --text2:    #555555;
  --text3:    #999999;
  --accent:   #2563eb;
  --accent-h: #3b82f6;
  --up:       #16a34a;
  --up-bg:    #f0fdf4;
  --up-bdr:   #bbf7d0;
  --dn:       #dc2626;
  --dn-bg:    #fff1f2;
  --dn-bdr:   #fda4af;
  --warn:     #92400e;
  --warn-bg:  #fffbeb;
  --warn-bdr: #fde68a;
  --purple:   #6b21a8;
  --purple-bg:#faf5ff;
  --purple-bdr:#e9d5ff;
  --amber:    #d97706;
  --amber-bg: #fffbeb;
  --amber-bdr:#fde68a;
  --radius:   12px;
  --radius-sm:6px;
  --shadow:   0 2px 8px rgba(0,0,0,.07);
}

*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI','Microsoft JhengHei',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5}

/* ── Layout ── */
.wrap{max-width:900px;margin:0 auto;padding:14px 12px;display:flex;flex-direction:column;gap:10px}

/* ── Banners ── */
.banner{border-radius:var(--radius-sm);padding:9px 14px;font-size:.8rem;font-weight:600;display:flex;align-items:center;gap:8px}
.banner-stale{background:var(--dn-bg);border:1px solid var(--dn-bdr);color:var(--dn)}
.banner-adj{background:var(--warn-bg);border:1px solid var(--warn-bdr);color:var(--warn)}

/* ── Header ── */
.hdr{background:linear-gradient(135deg,#1a1a2e,#16213e);border-radius:var(--radius);padding:14px 18px;box-shadow:var(--shadow);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.hdr-title{display:flex;align-items:center;gap:10px}
.hdr-title h1{font-size:1.05rem;font-weight:700;letter-spacing:.3px;color:#fff}
.hdr-title .tagline{font-size:.72rem;color:rgba(255,255,255,.5);margin-top:2px}
.hdr-right{display:flex;align-items:center;gap:8px}
.src-badge{font-size:.68rem;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:.5px}
.src-live{background:rgba(22,163,74,.15);color:#16a34a;border:1px solid rgba(22,163,74,.3)}
.src-db  {background:rgba(255,255,255,.12);color:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.2)}

input[type=date]#openDate{
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);border-radius:var(--radius-sm);
  color:#fff;font-size:.82rem;font-family:inherit;padding:6px 10px;
  cursor:pointer;min-height:36px;outline:none
}
input[type=date]#openDate::-webkit-calendar-picker-indicator{filter:invert(1);cursor:pointer}
input[type=date]#openDate:focus{border-color:rgba(255,255,255,.6)}

/* ── Card ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow)}
.card-title{font-size:.72rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.card-title .ct-icon{font-size:.9rem}

/* ── Inputs ── */
.num-input{
  background:#fff;border:1px solid #e0e0e0;border-radius:var(--radius-sm);
  color:#1a1a2e;font-size:.88rem;font-family:inherit;padding:5px 7px;
  width:80px;text-align:center;outline:none;
  font-variant-numeric:tabular-nums;transition:border-color .15s
}
.num-input:focus{border-color:var(--accent)}
.num-input:read-only{color:#999;cursor:default}
.num-input.weight-input{color:#b45309;border-color:#fde68a;background:#fffbeb}
.num-input.weight-input:focus{border-color:#f59e0b}

/* ── US Markets card ── */
.us-layout{display:grid;grid-template-columns:1fr 210px;gap:16px;align-items:start}
.market-tbl{width:100%;border-collapse:collapse}
.market-tbl th{color:var(--text3);font-size:.68rem;font-weight:600;padding:5px 8px;text-align:center;border-bottom:1px solid var(--border2)}
.market-tbl td{padding:5px 6px;text-align:center;border-bottom:1px solid var(--border2)}
.market-tbl tr:last-child td{border-bottom:none}
.market-tbl .name{font-weight:700;font-size:.9rem;text-align:left;padding-left:0;min-width:40px}
.market-tbl .name.dj {color:#4d9de0}
.market-tbl .name.nq {color:#9b72d0}
.market-tbl .name.spy{color:#3fb950}
.market-tbl .name.tsm{color:#e3b341}

.prev-row{margin-top:12px;padding-top:10px;border-top:1px solid var(--border2);display:flex;align-items:center;gap:10px}
.prev-row label{font-size:.72rem;color:var(--text2);white-space:nowrap}
.prev-row input{background:#fff;border:1px solid #e0e0e0;border-radius:var(--radius-sm);color:#1a1a2e;font-size:.95rem;font-weight:700;width:120px;text-align:center;padding:6px 8px;font-family:inherit;outline:none;font-variant-numeric:tabular-nums}
.prev-row input:focus{border-color:var(--accent)}

/* B5.3 OHLC row + meta badge */
.meta-badge{display:inline-block;font-size:.62rem;font-weight:600;color:var(--text2);background:var(--border2);padding:2px 8px;border-radius:10px;letter-spacing:.3px;text-transform:none;margin-left:8px}
.ohlc-row{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:8px}
.ohlc-box{background:#f7f9fc;border:1px solid var(--border2);border-radius:var(--radius-sm);padding:6px 4px;text-align:center}
.ohlc-box.highlight{background:#eff6ff;border-color:#bfdbfe}
.ohlc-box .ol{font-size:.6rem;color:var(--text3);font-weight:600;margin-bottom:2px}
.ohlc-box .ov{font-size:.95rem;font-weight:700;color:#1a1a2e;font-variant-numeric:tabular-nums}
.ohlc-box.highlight .ov{color:#2563eb}
.market-tbl .close-col{font-weight:600;font-size:.85rem;color:#1a1a2e;font-variant-numeric:tabular-nums;min-width:80px}
.market-tbl .sym-zh{color:var(--text3);font-size:.68rem;font-weight:500;margin-left:4px}

/* ── Results column ── */
.results-col{display:flex;flex-direction:column;gap:8px}
.rbox{border-radius:var(--radius-sm);padding:10px 12px;text-align:center;border:1px solid var(--border2)}
.rbox .rl{font-size:.65rem;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px}
.rbox .rv{font-size:1.4rem;font-weight:700;font-variant-numeric:tabular-nums;letter-spacing:-.5px}
.rbox-accent{background:#eff6ff;border-color:#bfdbfe}
.rbox-accent .rv{color:#2563eb}
.rbox-green{background:var(--up-bg);border-color:var(--up-bdr)}
.rbox-green .rv{color:var(--up)}
.rbox-neutral{background:var(--surface2)}
.rbox-neutral .rv{color:var(--text)}
.rbox-amber{background:var(--amber-bg);border-color:var(--amber-bdr)}
.rbox-amber .rv{color:var(--amber)}
.rbox-amber input{background:transparent;border:none;font-size:1.4rem;font-weight:700;color:#d97706;width:80px;text-align:center;font-family:inherit;font-variant-numeric:tabular-nums;outline:none}
.range-row{display:flex;align-items:center;justify-content:center;gap:8px;font-weight:700;font-size:1.15rem;font-variant-numeric:tabular-nums}
.rl-num{color:var(--up)}
.rh-num{color:var(--dn)}
.sep{color:var(--text3);font-weight:400;font-size:.9rem}

/* ── Stats table ── */
.stat-tbl{width:100%;border-collapse:collapse;font-size:.85rem}
.stat-tbl th{color:var(--text3);font-size:.68rem;font-weight:600;padding:5px 10px;text-align:center;border-bottom:1px solid var(--border)}
.stat-tbl th:first-child{text-align:left}
.stat-tbl td{padding:6px 8px;text-align:center;border-bottom:1px solid var(--border2);font-variant-numeric:tabular-nums}
.stat-tbl td:first-child{text-align:left;color:var(--text2);font-size:.8rem}
.stat-tbl .stat-val{font-weight:700;color:var(--text);font-size:.92rem}
.stat-tbl .atr-row td{color:var(--text3);font-size:.78rem}

.sigma-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
.sigma-box{background:var(--purple-bg);border:1px solid var(--purple-bdr);border-radius:var(--radius-sm);padding:10px;text-align:center}
.sigma-box .sl{font-size:.65rem;color:var(--purple);font-weight:700;margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px}
.sigma-box .sv{font-size:1.05rem;font-weight:700;color:var(--purple);font-variant-numeric:tabular-nums}

/* ── Weekday ── */
.week-row{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}
.week-box{background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:10px;text-align:center}
.week-box .wl{font-size:.68rem;color:var(--text2);font-weight:700;margin-bottom:4px;text-transform:uppercase}
.week-box .wv{font-size:1rem;font-weight:700;color:var(--accent-h);font-variant-numeric:tabular-nums}

/* ── Targets ── */
.bb-row{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}
.bb-box{background:var(--amber-bg);border:1px solid var(--amber-bdr);border-radius:var(--radius-sm);padding:10px;text-align:center}
.bb-box .bl{font-size:.68rem;color:var(--amber);font-weight:700;margin-bottom:4px}
.bb-box .bv{font-size:1.15rem;font-weight:700;color:var(--amber);font-variant-numeric:tabular-nums}
.bb-box.grand{background:#1e1500;border-color:#7c5600}
.bb-box.grand .bl{color:#fbbf24}
.bb-box.grand .bv{color:#fbbf24;font-size:1.2rem}

/* ── Direction (Long/Short) ── */
.dir-section{margin-top:14px;padding-top:14px;border-top:1px solid var(--border2)}
.open-price-hint{font-size:.72rem;color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.open-price-hint strong{color:var(--text);font-variant-numeric:tabular-nums}

.dir-header{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.dir-badge{font-size:.7rem;font-weight:700;padding:2px 9px;border-radius:4px}
.badge-long {background:var(--up-bg) ;border:1px solid var(--up-bdr);color:var(--up)}
.badge-short{background:var(--dn-bg) ;border:1px solid var(--dn-bdr);color:var(--dn)}
.dir-desc{font-size:.72rem;color:var(--text3)}

.dir-row{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:10px}
.dir-box{border-radius:var(--radius-sm);padding:9px 8px;text-align:center}
.dir-box .dl{font-size:.65rem;font-weight:700;margin-bottom:3px;letter-spacing:.3px}
.dir-box .dv{font-size:1rem;font-weight:700;font-variant-numeric:tabular-nums}
.dir-box.long-box{background:var(--up-bg);border:1px solid var(--up-bdr)}
.dir-box.long-box .dl{color:#6ee7a0}
.dir-box.long-box .dv{color:var(--up)}
.dir-box.short-box{background:var(--dn-bg);border:1px solid var(--dn-bdr)}
.dir-box.short-box .dl{color:#fca5a5}
.dir-box.short-box .dv{color:var(--dn)}

/* ── Guide ── */
.guide{display:flex;flex-direction:column;gap:0}
.guide p{font-size:.8rem;color:var(--text2);padding:6px 0;border-bottom:1px solid var(--border2);line-height:1.6}
.guide p:last-child{border-bottom:none}
.guide strong{color:var(--text)}

/* ── Footer ── */
.footer{text-align:center;font-size:.7rem;color:var(--text3);padding:6px 0 2px}

/* ── Loading ── */
body.loading{pointer-events:none}
body.loading::after{
  content:'載入中…';position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  background:rgba(26,26,46,.88);color:#fff;padding:12px 28px;
  border-radius:var(--radius);font-size:.95rem;z-index:9999;box-shadow:var(--shadow)
}
body.loading .wrap{opacity:.4;transition:opacity .2s}

/* ── Toast ── */
#_toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
  background:#1a1a2e;color:#fff;
  padding:10px 22px;border-radius:var(--radius-sm);font-size:.82rem;
  z-index:9999;pointer-events:none;opacity:0;transition:opacity .25s;
  white-space:nowrap;box-shadow:var(--shadow)
}

/* ── Responsive ── */
@media(max-width:640px){
  .us-layout{grid-template-columns:1fr}
  .results-col{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .week-row{grid-template-columns:repeat(3,1fr)}
  .bb-row,.dir-row{grid-template-columns:repeat(3,1fr)}
  .sigma-row{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>
<div id="_toast"></div>
<div class="wrap">

<div class="banner banner-stale" id="stale-banner" hidden>
  ⚠ 資料尚未更新，請等待下次自動更新。
</div>

<div class="banner banner-adj" id="adj-banner" hidden>
  ⚠ <span id="adj-banner-text"></span>
</div>

<!-- ── Header ── -->
<div class="hdr">
  <div class="hdr-title">
    <div>
      <h1>台指平均震幅分析</h1>
      <div class="tagline">TaiFX Volatility Dashboard</div>
    </div>
  </div>
  <div class="hdr-right">
    <span id="data-source-badge" class="src-badge {{ 'src-live' if data_source == 'live' else 'src-db' }}">{{ 'LIVE' if data_source == 'live' else 'DB' }}</span>
    <input type="date" id="openDate"
           value="{{ trading_date or server_today or effective_date or asof_iso }}"
           min="{{ earliest_db_date or '' }}"
           max="{{ server_today or '' }}"
           aria-label="查詢日期">
    <span class="meta-badge" id="effective-meta">適用交易日 {{ trading_date or effective_date or '—' }}</span>
  </div>
</div>

<!-- ── 美股 + 預估 ── -->
<div class="card">
  <div class="card-title">
    <span class="ct-icon">📈</span>美股漲跌幅 → 台指開盤預估
    <span class="meta-badge" id="us-meta">NYSE 收盤 {{ us_session_date or '—' }}</span>
  </div>
  <div class="us-layout">
    <div>
      <table class="market-tbl">
        <thead>
          <tr><th>商品</th><th>收盤</th><th>漲幅 (%)</th><th>權重 (%)</th></tr>
        </thead>
        <tbody>
          <tr>
            <td class="name dj">DJ<span class="sym-zh">道瓊工業</span></td>
            <td class="close-col" id="djClose">{{ '{:,.2f}'.format(us_data.dj.close) if us_data and us_data.dj else '—' }}</td>
            <td><input class="num-input" type="number" id="djC"  value="{{ '%.2f' | format(us_data.dj.pct if us_data and us_data.dj else us.dj) }}"  step="0.01" aria-label="DJ漲幅"></td>
            <td><input class="num-input weight-input" type="number" id="djW"  value="50" step="1" aria-label="DJ權重"></td>
          </tr>
          <tr>
            <td class="name nq">NQ<span class="sym-zh">那斯達克綜合</span></td>
            <td class="close-col" id="nqClose">{{ '{:,.2f}'.format(us_data.nq.close) if us_data and us_data.nq else '—' }}</td>
            <td><input class="num-input" type="number" id="nqC"  value="{{ '%.2f' | format(us_data.nq.pct if us_data and us_data.nq else us.nq) }}"  step="0.01" aria-label="NQ漲幅"></td>
            <td><input class="num-input weight-input" type="number" id="nqW"  value="50" step="1" aria-label="NQ權重"></td>
          </tr>
          <tr>
            <td class="name spy">SPY<span class="sym-zh">標普500</span></td>
            <td class="close-col" id="spyClose">{{ '{:,.2f}'.format(us_data.spy.close) if us_data and us_data.spy else '—' }}</td>
            <td><input class="num-input" type="number" id="spyC" value="{{ '%.2f' | format(us_data.spy.pct if us_data and us_data.spy else us.spy) }}" step="0.01" aria-label="SPY漲幅"></td>
            <td><input class="num-input weight-input" type="number" id="spyW" value="0"  step="1" aria-label="SPY權重"></td>
          </tr>
          <tr>
            <td class="name tsm">TSM<span class="sym-zh">台積電ADR</span></td>
            <td class="close-col" id="tsmClose">{{ '{:,.2f}'.format(us_data.tsm.close) if us_data and us_data.tsm else '—' }}</td>
            <td><input class="num-input" type="number" id="tsmC" value="{{ '%.2f' | format(us_data.tsm.pct if us_data and us_data.tsm else us.tsm) }}" step="0.01" aria-label="TSM漲幅"></td>
            <td><input class="num-input weight-input" type="number" id="tsmW" value="0"  step="1" aria-label="TSM權重"></td>
          </tr>
        </tbody>
      </table>
      <div class="prev-row" style="flex-direction:column;align-items:stretch;gap:6px">
        <div style="display:flex;align-items:baseline;gap:8px">
          <label style="font-weight:700;color:var(--text)">前日台指期收盤</label>
          <span class="meta-badge" id="txf-meta">{{ txf_symbol_label or '大臺近月（TXFR1）日盤' }} · {{ txf_ohlc.date if txf_ohlc else '—' }}</span>
        </div>
        <div class="ohlc-row">
          <div class="ohlc-box"><div class="ol">開</div><div class="ov" id="txfOpen">{{ '{:,.0f}'.format(txf_ohlc.open) if txf_ohlc else '—' }}</div></div>
          <div class="ohlc-box"><div class="ol">高</div><div class="ov" id="txfHigh">{{ '{:,.0f}'.format(txf_ohlc.high) if txf_ohlc else '—' }}</div></div>
          <div class="ohlc-box"><div class="ol">低</div><div class="ov" id="txfLow">{{ '{:,.0f}'.format(txf_ohlc.low) if txf_ohlc else '—' }}</div></div>
          <div class="ohlc-box highlight"><div class="ol">收</div><div class="ov" id="txfClose">{{ '{:,.0f}'.format(txf_ohlc.close) if txf_ohlc else '—' }}</div></div>
        </div>
        <!-- 保留 hidden input 維持 calculate() / prevClose 既有契約 -->
        <input type="hidden" id="prevClose" value="{{ txf_ohlc.close if txf_ohlc else prev_close }}">
      </div>
    </div>
    <div class="results-col">
      <div class="rbox rbox-accent">
        <div class="rl">加權美股漲幅 <span id="cum-chip" class="meta-badge" hidden style="font-size:.6rem;vertical-align:middle">區間累積</span></div>
        <div class="rv" id="wChg" aria-live="polite">—</div>
      </div>
      <div class="rbox rbox-green">
        <div class="rl">期貨預估開盤</div>
        <div class="rv" id="futEst" aria-live="polite">—</div>
      </div>
      <div class="rbox rbox-neutral">
        <div class="rl">合理範圍</div>
        <div class="range-row">
          <span class="rl-num" id="rLow" aria-live="polite">—</span>
          <span class="sep">～</span>
          <span class="rh-num" id="rHigh" aria-live="polite">—</span>
        </div>
      </div>
      <div class="rbox rbox-amber">
        <div class="rl">單位風險 R</div>
        <div class="rv"><input type="number" id="rR" value="{{ r }}" step="1" aria-label="單位風險R"></div>
      </div>
    </div>
  </div>
</div>

<!-- ── 震幅統計 ── -->
<div class="card">
  <div class="card-title"><span class="ct-icon">📊</span>震幅統計</div>
  <table class="stat-tbl">
    <thead>
      <tr><th>項目</th><th>20日</th><th>10日</th><th>5日</th></tr>
    </thead>
    <tbody>
      <tr>
        <td>平均振幅 (H-L)</td>
        <td><input class="num-input stat-val" type="number" id="a20" value="{{ stats.a20 }}" step="0.01"></td>
        <td><input class="num-input stat-val" type="number" id="a10" value="{{ stats.a10 }}" step="0.01"></td>
        <td><input class="num-input stat-val" type="number" id="a5"  value="{{ stats.a5  }}" step="0.01"></td>
      </tr>
      <tr>
        <td>振幅標準差</td>
        <td><input class="num-input stat-val" type="number" id="s20" value="{{ stats.s20 }}" step="0.01"></td>
        <td><input class="num-input stat-val" type="number" id="s10" value="{{ stats.s10 }}" step="0.01"></td>
        <td><input class="num-input stat-val" type="number" id="s5"  value="{{ stats.s5  }}" step="0.01"></td>
      </tr>
      <tr class="atr-row">
        <td>ATR (True Range)</td>
        <td id="atr20">{{ atr.atr20 }}</td>
        <td id="atr10">{{ atr.atr10 }}</td>
        <td id="atr5" >{{ atr.atr5  }}</td>
      </tr>
    </tbody>
  </table>
  <div class="sigma-row">
    <div class="sigma-box"><div class="sl">1σ 震幅</div><div class="sv" id="sig1" aria-live="polite">—</div></div>
    <div class="sigma-box"><div class="sl">2σ 震幅</div><div class="sv" id="sig2" aria-live="polite">—</div></div>
